#!/bin/bash

# findDups - Find duplicate files in user space and optionally delete local copies
#
# For each file in the current directory:
# - Find all other occurrences of that filename in user's home directory
# - Compare file size and hash to determine if files are identical
# - Prompt to delete local copy if identical duplicates exist elsewhere

for file in *; do
    # Skip if not a regular file
    if [ ! -f "$file" ]; then
        continue
    fi
    
    # Get absolute path of current file
    current_path=$(realpath "$file")
    
    # Find all instances of this filename in home directory
    # Redirect stderr to suppress permission denied errors
    matches=$(find ~/ -name "$file" -type f 2>/dev/null | grep -v "^${current_path}$")
    
    if [ -z "$matches" ]; then
        # No duplicates found - just list and continue
        echo "----------------------------------------"
        echo "File: $file (unique)"
        ls -lah "$file"
        echo
        continue
    fi
    
    # Get size and hash of current file
    current_size=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file")
    current_hash=$(sha256sum "$file" 2>/dev/null | awk '{print $1}' || shasum -a 256 "$file" | awk '{print $1}')
    
    echo "========================================"
    echo "File: $file"
    echo "Current location: $current_path"
    echo "  Size: $current_size bytes"
    echo "  Hash: $current_hash"
    ls -lah "$file" | awk '{print "  " $0}'
    echo
    echo "Found in other locations:"
    
    has_identical=false
    has_nonidentical=false
    identical_paths=""
    
    # Check each match
    while IFS= read -r match_path; do
        if [ -z "$match_path" ]; then
            continue
        fi
        
        match_size=$(stat -c%s "$match_path" 2>/dev/null || stat -f%z "$match_path")
        
        echo "  ----------------------------------------"
        echo "  Location: $match_path"
        ls -lah "$match_path" | awk '{print "    " $0}'
        echo "    Size: $match_size bytes"
        
        if [ "$current_size" != "$match_size" ]; then
            echo "    Status: ⚠ DIFFERENT - Size differs (current: $current_size, other: $match_size)"
            has_nonidentical=true
        else
            match_hash=$(sha256sum "$match_path" 2>/dev/null | awk '{print $1}' || shasum -a 256 "$match_path" | awk '{print $1}')
            echo "    Hash: $match_hash"
            if [ "$current_hash" = "$match_hash" ]; then
                echo "    Status: ✓ IDENTICAL (same size and content)"
                has_identical=true
                identical_paths="${identical_paths}${match_path}\n"
            else
                echo "    Status: ⚠ DIFFERENT - Size matches but content differs"
                echo "      Current hash: $current_hash"
                echo "      Other hash:   $match_hash"
                has_nonidentical=true
            fi
        fi
        echo
    done <<< "$matches"
    
    # Prompt user
    echo "----------------------------------------"
    if [ "$has_identical" = true ]; then
        echo "✓ At least one IDENTICAL copy exists elsewhere."
        if [ "$has_nonidentical" = true ]; then
            echo "⚠ Also found non-identical files with same name."
        fi
        echo
        while true; do
            read -p "Delete current file '$file'? [D=delete, Return=skip]: " choice
            case "$choice" in
                [Dd])
                    rm -v "$file"
                    echo "✓ Deleted: $file"
                    break
                    ;;
                "")
                    echo "○ Skipped"
                    break
                    ;;
                *)
                    echo "Invalid choice. Use 'D' to delete or press Return to skip."
                    ;;
            esac
        done
    else
        if [ "$has_nonidentical" = true ]; then
            echo "⚠ Found files with same name but DIFFERENT content (not duplicates)."
        else
            echo "○ No identical duplicates found."
        fi
        read -p "Press Return to continue..." dummy
    fi
    echo
done

echo "========================================"
echo "Scan complete."
